{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Bridge",
  "version": "0.1.0",
  "identifier": "com.grokbridge.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Grok Bridge",
        "width": 1180,
        "height": 760,
        "resizable": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/grok-bridge"
    ]
  }
}
